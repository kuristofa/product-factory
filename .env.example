# ─────────────────────────────────────────────────────────────
#  AI Product Production Factory — configuration
#  Generation runs through the Claude Code CLI on your logged-in
#  Max account. There is NO API key to set.
# ─────────────────────────────────────────────────────────────

# Optional: pin a model. Leave blank to use your Claude Code session default.
#   e.g. claude-sonnet-5  or  claude-opus-4-8
CLAUDE_MODEL=

# How long to wait for a single generation call (seconds).
CLAUDE_TIMEOUT_SECONDS=300

# Default DM-automation tool, used when a brief doesn't set its own "dm_tool".
# Per-product, set "dm_tool" in the brief instead. Examples: ManyChat, Chatfuel, InstaChamp.
DM_TOOL=ManyChat

# Paths (defaults are fine)
OUTPUT_DIR=output
BRIEFS_DIR=briefs

# Optional: path to your extracted Maria Wendt course notes. Contents are injected
# into every generation prompt as grounding. Leave blank for the built-in methodology.
METHODOLOGY_NOTES_PATH=
